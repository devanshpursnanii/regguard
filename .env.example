NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
GEMINI_API_KEY=your_gemini_key
RESEND_API_KEY=your_resend_key
FROM_EMAIL=onboarding@resend.dev

CORS_ALLOW_ORIGINS=http://localhost:5173

GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2
LLM_TEMPERATURE=0.1
LLM_MAX_RPM=6
LLM_CACHE_DIR=.llm_cache
RAPTOR_ENABLED=false
RAPTOR_GROUP_SIZE=15
RAPTOR_ENABLE_DOC_SUMMARY=false
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=50
TOP_K_RETRIEVAL=8
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.5
GRAPH_WEIGHT=0.2
CONFIDENCE_THRESHOLD=0.4
PARTIAL_THRESHOLD=0.7
RAPTOR_LEVELS=3
QDRANT_MODE=in_memory

CITATION_REGULATORY="[{regulation_id}, Clause {clause_number}]"
CITATION_COMPANY="[{company_name}, p.{page_number}]"
CITATION_EVIDENCE="{regulatory_citation} \u2194 {company_citation}"
